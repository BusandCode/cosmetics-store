generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING // cart converted to order, awaiting payment action
  AWAITING_CONFIRMATION // manual transfer: customer says "I've paid"
  PAID // confirmed paid (manual admin confirm OR paystack webhook)
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  MANUAL_TRANSFER
  PAYSTACK
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  phone     String?
  password  String
  role      Role      @default(CUSTOMER)
  addresses Address[]
  orders    Order[]
  createdAt DateTime  @default(now())
}

model Address {
  id       String  @id @default(cuid())
  user     User    @relation(fields: [userId], references: [id])
  userId   String
  fullName String
  phone    String
  line1    String
  city     String
  state    String
  orders   Order[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

model Product {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String
  images      String[]
  category    Category         @relation(fields: [categoryId], references: [id])
  categoryId  String
  variants    ProductVariant[]
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
}

model ProductVariant {
  id         String      @id @default(cuid())
  product    Product     @relation(fields: [productId], references: [id])
  productId  String
  label      String // e.g. "50ml", "Medium", "Red"
  sku        String      @unique
  priceKobo  Int // store in kobo to avoid float issues
  stock      Int         @default(0)
  orderItems OrderItem[]
}

model Order {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id])
  userId    String
  address   Address     @relation(fields: [addressId], references: [id])
  addressId String
  items     OrderItem[]
  status    OrderStatus @default(PENDING)
  totalKobo Int
  reference String      @unique // shown to customer as transfer narration / paystack ref
  payment   Payment?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model OrderItem {
  id        String         @id @default(cuid())
  order     Order          @relation(fields: [orderId], references: [id])
  orderId   String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  variantId String
  quantity  Int
  priceKobo Int // snapshot of price at purchase time
}

model Payment {
  id            String        @id @default(cuid())
  order         Order         @relation(fields: [orderId], references: [id])
  orderId       String        @unique
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amountKobo    Int
  paystackRef   String?
  confirmedById String? // admin user id, for manual confirmations
  confirmedAt   DateTime?
  createdAt     DateTime      @default(now())
}
